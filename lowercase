/* Force lowercase tab titles */
.tab-label,
.tabbrowser-tab .tab-text,
.tab-text {
  text-transform: lowercase !important;
}

/* Optional: Keep the first letter capitalized (title-case style) if you prefer */
.tab-label::first-letter,
.tabbrowser-tab .tab-text::first-letter {
  text-transform: uppercase !important;
}
